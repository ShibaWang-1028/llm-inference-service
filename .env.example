# Copy this to .env for local development:  cp .env.example .env
# Nothing here is secret by default. Fill in real keys only when you wire up
# the cloud services (Langfuse, OTel/Grafana). The gateway runs fine with the
# defaults below pointed at the local fake upstream.

# ---- Upstream inference engine ----
# In production this is the local vLLM server. For local dev, point it at the
# fake upstream (tools/fake_vllm.py), which also listens on 8000 by default.
UPSTREAM_BASE_URL=http://127.0.0.1:8000

# Model identifiers. MODEL_ID is what vLLM loads; MODEL_NAME is the friendly
# name shown in the API and in Langfuse cost tracking.
MODEL_ID=Qwen/Qwen2.5-7B-Instruct-AWQ
MODEL_NAME=Qwen2.5-7B-Instruct

# ---- Gateway auth ----
# Comma-separated list of allowed API keys (sent as "Authorization: Bearer <key>").
# Leave EMPTY to disable auth for local development (a warning is logged).
API_KEYS=

# A public demo key the chat UI uses automatically so visitors don't type anything.
# It counts as a valid key but is rate-limited per client IP. Leave empty locally.
DEMO_API_KEY=

# ---- Rate limiting ----
# slowapi-style limit string, applied per API key (or per client IP if no key).
RATE_LIMIT=60/minute

# ---- Timeouts / server ----
REQUEST_TIMEOUT_S=120
PORT=8080
LOG_LEVEL=info

# ---- Langfuse (per-request token + cost tracking) ----
# Optional. Set ENABLE_LANGFUSE=true and fill the keys to turn it on.
ENABLE_LANGFUSE=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- OpenTelemetry traces (-> Grafana Cloud Tempo) ----
# Optional. Set ENABLE_OTEL=true and fill the endpoint/headers to turn it on.
ENABLE_OTEL=false
OTEL_SERVICE_NAME=llm-inference-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=
# For Grafana Cloud, the header value must use %20 instead of a space:
#   Authorization=Basic%20<base64(instanceID:token)>
OTEL_EXPORTER_OTLP_HEADERS=

  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "llm",
    "vllm",
    "inference"
  ],
  "templating": {
    "list": [
      {
        "name": "gpu_cost_per_hour",
        "type": "constant",
        "label": "Instance cost per hour (USD)",
        "query": "1.65",
        "current": {
          "text": "1.65",
          "value": "1.65"
        },
        "hide": 0
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "title": "LLM Inference Service",
  "uid": "llm-inference",
  "version": 1,
  "weekStart": ""
}